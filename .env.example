# Logging settings
LIB_LOG_LEVEL=INFO                       # Root log level: `DEBUG`, `INFO`, `WARNING`, `ERROR`, `CRITICAL`
LIB_LOG_CONSOLE_LEVEL=DEBUG              # Minimum level printed to the console
LIB_LOG_FILE_LEVEL=INFO                  # Minimum level written to the log file
LIB_LOG_FILE_NAME=lib.log               # Log file name (written to the logs/ directory in the project root)
LIB_LOG_USE_JSON_FORMATTER=false         # Emit log records as JSON (useful for log aggregators)
